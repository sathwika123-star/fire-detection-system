EMAIL_PORT=587
EMAIL_HOST_USER=padirishitha13@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
DEFAULT_FROM_EMAIL=padirishitha13@gmail.com
SERVER_EMAIL=padirishitha13@gmail.com

# Twilio Settings (for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
